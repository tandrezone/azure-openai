{
    "name": "tandrezone/azure-openai",
    "description": "A PHP package to interact with Azure OpenAI Service using openai-php/client.",
    "keywords": ["azure", "openai", "azure-openai", "php", "ai"],
    "homepage": "https://github.com/tandrezone/azure-openai",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.2",
        "openai-php/client": "^0.10"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Tandrezone\\AzureOpenAI\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tandrezone\\AzureOpenAI\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist"
    },
    "minimum-stability": "stable"
}
